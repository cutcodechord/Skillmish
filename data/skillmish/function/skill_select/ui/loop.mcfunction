#> skillmish:skill_select/ui/loop
#

# ループ

# 決定
    execute unless items block ~ ~ ~ container.7 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.decide":true}] run function skillmish:skill_select/ui/decide_box
    execute unless items block ~ ~ ~ container.8 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.exit":true}] run function skillmish:skill_select/ui/exit_box

# 取り外す
