    function c3func:inventory_manage/container_reset {slot:"container.6",slot_nbt:"6b",item:"minecraft:name_tag[minecraft:max_stack_size=1,minecraft:item_model=\"minecraft:gray_stained_glass_pane\",minecraft:item_name='[{\"text\":\" \",\"color\":\"white\"}]',minecraft:custom_data={\"skillmish.process.mustbe_deleted\":true}]"}

