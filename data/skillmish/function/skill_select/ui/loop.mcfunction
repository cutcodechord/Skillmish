#> skillmish:skill_select/ui/loop
#

# ループ

# 決定
    execute unless items block ~ ~ ~ container.7 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.decide":"true"}] run function skillmish:skill_select/ui/decide_box
    execute unless items block ~ ~ ~ container.8 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.exit":"true"}] run function skillmish:skill_select/ui/exit_box

# 取り外す
    execute if entity @s[tag=skillmish.process.ui_box.can_remove_1] unless items block ~ ~ ~ container.0 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_1":"true"}] run function skillmish:skill_select/ui/remove_1
    execute if entity @s[tag=skillmish.process.ui_box.can_remove_2] unless items block ~ ~ ~ container.1 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_2":"true"}] run function skillmish:skill_select/ui/remove_2
    execute if entity @s[tag=skillmish.process.ui_box.can_remove_3] unless items block ~ ~ ~ container.2 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_3":"true"}] run function skillmish:skill_select/ui/remove_3

# 取り外すボタンを有効化
    execute if items block ~ ~ ~ container.3 * run item replace block ~ ~ ~ container.0 with minecraft:name_tag[minecraft:item_model="minecraft:red_stained_glass_pane",minecraft:item_name='[{"text":"< ","color":"gray"},{"text":"取り外す","color":"red"},{"text":" >","color":"gray"}]',minecraft:custom_data={"skillmish.process.item.ui_box.remove_1":"true"}]
    execute if items block ~ ~ ~ container.3 * run tag @s add skillmish.process.ui_box.can_remove_1
    execute if items block ~ ~ ~ container.4 * run item replace block ~ ~ ~ container.1 with minecraft:name_tag[minecraft:item_model="minecraft:red_stained_glass_pane",minecraft:item_name='[{"text":"< ","color":"gray"},{"text":"取り外す","color":"red"},{"text":" >","color":"gray"}]',minecraft:custom_data={"skillmish.process.item.ui_box.remove_2":"true"}]
    execute if items block ~ ~ ~ container.4 * run tag @s add skillmish.process.ui_box.can_remove_2
    execute if items block ~ ~ ~ container.5 * run item replace block ~ ~ ~ container.2 with minecraft:name_tag[minecraft:item_model="minecraft:red_stained_glass_pane",minecraft:item_name='[{"text":"< ","color":"gray"},{"text":"取り外す","color":"red"},{"text":" >","color":"gray"}]',minecraft:custom_data={"skillmish.process.item.ui_box.remove_3":"true"}]
    execute if items block ~ ~ ~ container.5 * run tag @s add skillmish.process.ui_box.can_remove_3

# 取り外すボタンを無効化
    execute unless items block ~ ~ ~ container.3 * run item replace block ~ ~ ~ container.0 with minecraft:name_tag[minecraft:item_model="minecraft:gray_stained_glass_pane",minecraft:item_name='[{"text":" ","color":"white"}]',minecraft:custom_data={"skillmish.process.mustbe_deleted":"true"}]
    execute unless items block ~ ~ ~ container.3 * run tag @s remove skillmish.process.ui_box.can_remove_1
    execute unless items block ~ ~ ~ container.4 * run item replace block ~ ~ ~ container.1 with minecraft:name_tag[minecraft:item_model="minecraft:gray_stained_glass_pane",minecraft:item_name='[{"text":" ","color":"white"}]',minecraft:custom_data={"skillmish.process.mustbe_deleted":"true"}]
    execute unless items block ~ ~ ~ container.4 * run tag @s remove skillmish.process.ui_box.can_remove_2
    execute unless items block ~ ~ ~ container.5 * run item replace block ~ ~ ~ container.2 with minecraft:name_tag[minecraft:item_model="minecraft:gray_stained_glass_pane",minecraft:item_name='[{"text":" ","color":"white"}]',minecraft:custom_data={"skillmish.process.mustbe_deleted":"true"}]
    execute unless items block ~ ~ ~ container.5 * run tag @s remove skillmish.process.ui_box.can_remove_3

# 操作不能範囲
    function c3func:inventory_manage/container_reset {slot:"container.6",slot_nbt:"6b",item:"minecraft:name_tag[minecraft:item_model=\"minecraft:gray_stained_glass_pane\",minecraft:item_name='[{\"text\":\" \",\"color\":\"white\"}]',minecraft:custom_data={\"skillmish.process.mustbe_deleted\":\"true\"}]"}

# 決定ボタン
    function c3func:inventory_manage/container_reset {slot:"container.7",slot_nbt:"7b",item:"minecraft:name_tag[minecraft:item_model=\"minecraft:trial_key\",minecraft:item_name='[{\"text\":\"< \",\"color\":\"gray\"},{\"text\":\"決定!\",\"color\":\"green\"},{\"text\":\" >\",\"color\":\"gray\"}]',minecraft:custom_data={\"skillmish.process.item.ui_box.decide\":\"true\"}]"}

# 退出ボタン
    function c3func:inventory_manage/container_reset {slot:"container.8",slot_nbt:"8b",item:"minecraft:name_tag[minecraft:item_model=\"minecraft:structure_void\",minecraft:item_name='[{\"text\":\"< \",\"color\":\"gray\"},{\"text\":\"終了\",\"color\":\"red\"},{\"text\":\" >\",\"color\":\"gray\"}]',minecraft:custom_data={\"skillmish.process.item.ui_box.exit\":\"true\"}]"}

