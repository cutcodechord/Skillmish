    function c3func:inventory_manage/container_reset {slot:"container.7",slot_nbt:"7b",item:"minecraft:name_tag[minecraft:max_stack_size=1,minecraft:item_model=\"minecraft:trial_key\",minecraft:item_name='[{\"text\":\"< \",\"color\":\"gray\"},{\"text\":\"決定!\",\"color\":\"green\"},{\"text\":\" >\",\"color\":\"gray\"}]',minecraft:custom_data={\"skillmish.process.item.ui_box.decide\":true}]"}

