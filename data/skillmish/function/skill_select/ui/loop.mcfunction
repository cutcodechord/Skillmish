    execute if entity @s[tag=skillmish.process.ui_box.can_remove_1] unless items block ~ ~ ~ container.0 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_1":true}] run function skillmish:skill_select/ui/remove_1
    execute if entity @s[tag=skillmish.process.ui_box.can_remove_2] unless items block ~ ~ ~ container.1 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_2":true}] as @a if items entity @s player.cursor minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_2":true}] run playsound minecraft:item.axe.scrape block @s ~ ~ ~ 1 0.9
