    execute if entity @s[tag=skillmish.process.ui_box.can_remove_3] unless items block ~ ~ ~ container.2 minecraft:name_tag[minecraft:custom_data={"skillmish.process.item.ui_box.remove_3":true}] run function skillmish:skill_select/ui/remove_3

# 取り外すボタンを有効化
    execute if items block ~ ~ ~ container.3 * run item replace block ~ ~ ~ container.0 with minecraft:name_tag[minecraft:max_stack_size=1,minecraft:item_model="minecraft:red_stained_glass_pane",minecraft:item_name='[{"text":"< ","color":"gray"},{"text":"取り外す","color":"red"},{"text":" >","color":"gray"}]',minecraft:custom_data={"skillmish.process.item.ui_box.remove_1":true}]
    execute if items block ~ ~ ~ container.3 * run tag @s add skillmish.process.ui_box.can_remove_1
    execute if items block ~ ~ ~ container.4 * run item replace block ~ ~ ~ container.1 with minecraft:name_tag[minecraft:max_stack_size=1,minecraft:item_model="minecraft:red_stained_glass_pane",minecraft:item_name='[{"text":"< ","color":"gray"},{"text":"取り外す","color":"red"},{"text":" >","color":"gray"}]',minecraft:custom_data={"skillmish.process.item.ui_box.remove_2":true}]
